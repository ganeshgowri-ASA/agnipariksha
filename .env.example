# Agnipariksha Environment Variables
# Copy this to frontend/.env.local and fill in values

# Claude AI API Key (for AI Assistant tab)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Backend WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/live

# ITECH Device IP (default from device.xml)
ITECH_DEVICE_IP=192.168.200.100
ITECH_DEVICE_PORT=30000

# Demo mode (true = simulated data, false = real hardware)
DEMO_MODE=true

# ----------------------------------------------------------------
# V2-S7 — remote monitoring + barcode/QR + push notifications
# ----------------------------------------------------------------

# JWT auth on /api/* and /ws/* — keep AUTH_ENABLED=false for dev/demo.
AUTH_ENABLED=false
JWT_SECRET=change-me-to-a-32-byte-random-string
JWT_ALG=HS256
JWT_AUDIENCE=agnipariksha

# VAPID keys for Web Push. Generate with:
#   python -c "from py_vapid import Vapid01; v=Vapid01(); v.generate_keys(); \
#       print('pub=', v.public_key_to_b64()); print('priv=', v.private_key_to_b64())"
# Or use any standards-compliant VAPID generator. Leave blank to disable push.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@agnipariksha.local

# Backend HTTP origin used by the Next.js rewrites for /api/push/* and
# /modules/<id>/label proxies. Override when serving the frontend from a
# separate host (e.g. behind a Cloudflare Tunnel).
NEXT_PUBLIC_BACKEND_HTTP=http://localhost:8000
