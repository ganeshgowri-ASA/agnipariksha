# Agnipariksha Environment Variables

# Hardware
ITECH_IP=192.168.200.100
ITECH_PORT=30000
ITECH_TIMEOUT=5
DEMO_MODE=false

# Database (TimescaleDB)
DATABASE_URL=postgresql://agnipariksha:agnipariksha@localhost:5432/agnipariksha
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agnipariksha
DB_USER=agnipariksha
DB_PASSWORD=agnipariksha

# Backend
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:1420

# AI / Claude MCP
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
MCP_SERVER_PORT=3100

# Reports
REPORT_OUTPUT_DIR=./reports
COMPANY_NAME=Shreshtata Power Supplies
COMPANY_LOGO=./assets/shreshtata-logo.png

# Deployment
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_VERSION=1.0.0
