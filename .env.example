# Agnipariksha Environment Variables
# Copy this to frontend/.env.local and fill in values

# Claude AI API Key (for AI Assistant tab)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Backend WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/live

# ITECH Device IP (default from device.xml)
ITECH_DEVICE_IP=192.168.200.100
ITECH_DEVICE_PORT=30000

# Demo mode (true = simulated data, false = real hardware)
DEMO_MODE=true
