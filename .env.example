# Agnipariksha Environment Variables
# Copy this to frontend/.env.local and fill in values

# Claude AI API Key — read by the backend agent ONLY. Never expose
# this to the browser. Leave blank to run the deterministic offline
# fallback (still grounded in the tool surface).
ANTHROPIC_API_KEY=
# Optional override of the LLM model id (default: claude-sonnet-4-6).
AGNI_LLM_MODEL=

# Optional override of the AI agent's SQLite path (default:
# repo-root/data/agnipariksha.db).
AGNI_DB_PATH=

# Backend WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/telemetry
NEXT_PUBLIC_BACKEND_HTTP_URL=http://localhost:8000

# ITECH Device IP (default from device.xml)
ITECH_DEVICE_IP=192.168.200.100
ITECH_DEVICE_PORT=30000

# Demo mode (true = simulated data, false = real hardware)
DEMO_MODE=true
