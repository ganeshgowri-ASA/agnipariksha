# Agnipariksha Frontend Environment

# Live data WebSocket from FastAPI backend
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/live

# REST API base for the FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Device identity displayed in the header (ITECH PV6000)
NEXT_PUBLIC_DEVICE_IP=192.168.200.100
NEXT_PUBLIC_DEVICE_PORT=30000

# AI providers for the assistant tab (server-side only)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Start in synthetic-data demo mode when true
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true
