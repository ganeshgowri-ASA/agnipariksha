# Agnipariksha backend configuration. Copy to backend/.env and edit.

# --- Hardware ---
ITECH_IP=192.168.200.100
ITECH_PORT=30000
ITECH_TIMEOUT_MS=500
DEMO_MODE=true

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs

# --- CORS allowlist (comma-separated) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:1420

# --- Persistence (V2-S2) ---
# Default: file-backed SQLite under <cwd>/data/. Postgres optional, e.g.:
#   DATABASE_URL=postgresql+psycopg://agni:agni@localhost:5432/agnipariksha
DATABASE_URL=sqlite:///./data/agnipariksha.db
CSV_RUNS_DIR=data/runs
DB_BACKFILL_ON_STARTUP=true

# --- Anthropic / AI proxy (server-side only; never expose to client) ---
# ANTHROPIC_API_KEY=
